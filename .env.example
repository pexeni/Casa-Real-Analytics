# Casa Real Analytics — env vars
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# ─── Database (Vercel Postgres / Neon) ──────────────────────────────────────
POSTGRES_URL=

# ─── File storage (Vercel Blob) ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Auth.js v5 ─────────────────────────────────────────────────────────────
# 32+ random bytes — generate with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the app (no trailing slash)
AUTH_URL=http://localhost:3000

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@example.com

# ─── Access control ─────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to sign in (case-insensitive).
ALLOWED_EMAILS=

# ─── LLM (OpenRouter) ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── App identity (for OpenRouter attribution headers) ──────────────────────
APP_URL=http://localhost:3000
